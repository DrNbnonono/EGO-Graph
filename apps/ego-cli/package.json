{
  "name": "@ego-graph/ego-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "ego": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:tui": "bun run --conditions=browser src/index.ts",
    "test": "cd ../.. && vitest run apps/ego-cli/test",
    "test:tui:visual": "bun test --preload @opentui/solid/preload --conditions=browser ./test/tui/opentui-smoke.bun.tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ego-graph/agent": "workspace:*",
    "@ego-graph/agent-harness": "workspace:*",
    "@ego-graph/core": "workspace:*",
    "@ego-graph/ego-api": "workspace:*",
    "@ego-graph/llm": "workspace:*",
    "@ego-graph/overlays": "workspace:*",
    "@ego-graph/report": "workspace:*",
    "@ego-graph/shared": "workspace:*",
    "@ego-graph/storage": "workspace:*",
    "@ego-graph/terminal-agent": "workspace:*",
    "@ego-graph/workbench": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "@opentui/core": "0.3.4",
    "@opentui/keymap": "0.3.4",
    "@opentui/solid": "0.3.4",
    "commander": "^12.1.0",
    "solid-js": "1.9.12"
  },
  "devDependencies": {}
}
