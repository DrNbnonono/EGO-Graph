{
  "name": "ego-graph",
  "version": "0.1.0",
  "private": true,
  "description": "Evidence-Guided Orchestration Graph cybersecurity agent",
  "type": "module",
  "bin": {
    "ego": "apps/ego-cli/dist/index.js"
  },
  "scripts": {
    "build": "pnpm -r --sort --workspace-concurrency=1 build",
    "clean": "node scripts/clean.mjs",
    "dev": "tsx apps/ego-cli/src/index.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "eval": "node scripts/eval.mjs",
    "eval:smoke": "node scripts/eval.mjs --smoke",
    "smoke": "node scripts/smoke.mjs",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "ego": "node apps/ego-cli/dist/index.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.7.0",
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.18",
    "eslint": "^9.18.0",
    "execa": "^9.5.2",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
